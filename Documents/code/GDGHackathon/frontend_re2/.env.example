# =============================================================================
# FRONTEND — copy to frontend_re2/.env.local and fill in values
# Restart: npm run dev
# =============================================================================

# Firebase Web SDK (Firebase Console → Project settings → Your apps → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=lattice-2026.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=lattice-2026
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=lattice-2026.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Live RBAC backend (do not point at emulators unless debugging locally)
NEXT_PUBLIC_RBAC_REGION=asia-southeast1
NEXT_PUBLIC_RBAC_FIRESTORE_DATABASE=rbac-new-db

# Development login panel on /login in production builds
NEXT_PUBLIC_SHOW_DEMO_LOGINS=true

# Optional — local Firebase emulators only
# NEXT_PUBLIC_USE_AUTH_EMULATOR=true
# NEXT_PUBLIC_USE_FUNCTIONS_EMULATOR=true

# NOTE: Gemini API key is NOT set here. It lives on the Cloud Run service for rbacApi.
# See backend_re2/rbac/.env.example and Google Cloud Console → Cloud Run → rbacapi.
