# READ-ONLY source (live parallel DB — never written by cloneDB.js)
SOURCE_DATABASE=(default)

# WRITE target (RBAC isolated database)
TARGET_DATABASE=rbac-new-db

# Set true only for Emulator Suite; false for production clone/deploy
USE_FIRESTORE_EMULATOR=false
USE_GRAPH_RAG=true
USE_GEMINI_SUMMARIES=false
USE_GEMINI_EMBEDDINGS=false
# GEMINI_API_KEY=your-key-here
# GEMINI_TEXT_MODEL=gemini-2.0-flash-lite
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# Production only: path to service account JSON with Firestore read (source) + write (target)
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Optional: batch size (max 500)
CLONE_BATCH_SIZE=400
